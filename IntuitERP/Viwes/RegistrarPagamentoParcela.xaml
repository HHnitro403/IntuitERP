<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IntuitERP.Viwes.RegistrarPagamentoParcela"
             Shell.NavBarIsVisible="False"
             Title="Registrar Pagamento">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryDarkBlue">#1B4F83</Color>
            <Color x:Key="PrimaryMidBlue">#55A2D3</Color>
            <Color x:Key="SuccessColor">#34A853</Color>
            <Color x:Key="ErrorColor">#D32F2F</Color>
            <Color x:Key="WarningColor">#FF9800</Color>
            <Color x:Key="White">#FFFFFF</Color>

            <Style x:Key="LabelTitle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="Gray" />
            </Style>

            <Style x:Key="LabelValue" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="SuccessButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource SuccessColor}" />
                <Setter Property="TextColor" Value="{StaticResource White}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HeightRequest" Value="50" />
            </Style>

            <Style x:Key="CancelButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ErrorColor}" />
                <Setter Property="TextColor" Value="{StaticResource White}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HeightRequest" Value="50" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Header -->
            <Frame BackgroundColor="{StaticResource PrimaryDarkBlue}" CornerRadius="10" Padding="15" HasShadow="True">
                <StackLayout Spacing="5">
                    <Label x:Name="TituloLabel"
                           Text="Registrar Pagamento - Parcela #1"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label x:Name="ContaLabel"
                           Text="Conta a Receber #123"
                           FontSize="14"
                           TextColor="White"
                           HorizontalOptions="Center" />
                </StackLayout>
            </Frame>

            <!-- Parcela Information -->
            <Frame Padding="15" CornerRadius="8" BorderColor="LightGray" HasShadow="True">
                <StackLayout Spacing="12">
                    <Label Text="Informações da Parcela" FontSize="16" FontAttributes="Bold" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                        <!-- Row 0: Vencimento and Status -->
                        <StackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Vencimento:" Style="{StaticResource LabelTitle}" />
                            <Label x:Name="VencimentoLabel" Text="01/01/2025" Style="{StaticResource LabelValue}" />
                        </StackLayout>
                        <StackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="Status:" Style="{StaticResource LabelTitle}" />
                            <Label x:Name="StatusLabel" Text="Vencido" Style="{StaticResource LabelValue}" TextColor="{StaticResource ErrorColor}" />
                        </StackLayout>

                        <!-- Row 1: Valor Original and Dias Atraso -->
                        <StackLayout Grid.Row="1" Grid.Column="0">
                            <Label Text="Valor Original:" Style="{StaticResource LabelTitle}" />
                            <Label x:Name="ValorOriginalLabel" Text="R$ 0,00" Style="{StaticResource LabelValue}" />
                        </StackLayout>
                        <StackLayout Grid.Row="1" Grid.Column="1">
                            <Label Text="Dias de Atraso:" Style="{StaticResource LabelTitle}" />
                            <Label x:Name="DiasAtrasoLabel" Text="0 dias" Style="{StaticResource LabelValue}" />
                        </StackLayout>

                        <!-- Row 2: Valor Já Pago -->
                        <StackLayout Grid.Row="2" Grid.Column="0">
                            <Label Text="Valor Já Pago:" Style="{StaticResource LabelTitle}" />
                            <Label x:Name="ValorJaPagoLabel" Text="R$ 0,00" Style="{StaticResource LabelValue}" TextColor="{StaticResource SuccessColor}" />
                        </StackLayout>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Payment Details -->
            <Frame Padding="15" CornerRadius="8" BorderColor="LightGray" HasShadow="True">
                <StackLayout Spacing="12">
                    <Label Text="Detalhes do Pagamento" FontSize="16" FontAttributes="Bold" />

                    <!-- Data Pagamento -->
                    <StackLayout>
                        <Label Text="Data do Pagamento:" FontSize="14" />
                        <DatePicker x:Name="DataPagamentoPicker" Format="dd/MM/yyyy" />
                    </StackLayout>

                    <!-- Forma Pagamento -->
                    <StackLayout>
                        <Label Text="Forma de Pagamento:" FontSize="14" />
                        <Picker x:Name="FormaPagamentoPicker" Title="Selecione">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Dinheiro</x:String>
                                    <x:String>PIX</x:String>
                                    <x:String>Cartão de Débito</x:String>
                                    <x:String>Cartão de Crédito</x:String>
                                    <x:String>Transferência Bancária</x:String>
                                    <x:String>Cheque</x:String>
                                    <x:String>Boleto</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Calculations -->
            <Frame Padding="15" CornerRadius="8" BorderColor="LightGray" HasShadow="True">
                <StackLayout Spacing="12">
                    <Label Text="Cálculos" FontSize="16" FontAttributes="Bold" />

                    <!-- Auto-calculated Juros and Multa -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                        <!-- Row 0: Juros -->
                        <StackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Juros (calculado):" Style="{StaticResource LabelTitle}" />
                            <Label x:Name="JurosLabel" Text="R$ 0,00" Style="{StaticResource LabelValue}" TextColor="{StaticResource ErrorColor}" />
                        </StackLayout>

                        <!-- Row 0: Multa -->
                        <StackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="Multa (calculada):" Style="{StaticResource LabelTitle}" />
                            <Label x:Name="MultaLabel" Text="R$ 0,00" Style="{StaticResource LabelValue}" TextColor="{StaticResource ErrorColor}" />
                        </StackLayout>

                        <!-- Row 1: Desconto -->
                        <StackLayout Grid.Row="1" Grid.ColumnSpan="2">
                            <Label Text="Desconto (opcional):" FontSize="14" />
                            <Entry x:Name="DescontoEntry"
                                   Keyboard="Numeric"
                                   Placeholder="0,00"
                                   TextChanged="DescontoEntry_TextChanged" />
                        </StackLayout>

                        <!-- Row 2: Valor Total -->
                        <StackLayout Grid.Row="2" Grid.ColumnSpan="2" Padding="0,10,0,0">
                            <BoxView HeightRequest="1" Color="LightGray" />
                            <Label Text="Valor Total a Pagar:" FontSize="14" Margin="0,10,0,0" />
                            <Label x:Name="ValorTotalLabel"
                                   Text="R$ 0,00"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDarkBlue}" />
                        </StackLayout>

                        <!-- Row 3: Valor do Pagamento -->
                        <StackLayout Grid.Row="3" Grid.ColumnSpan="2">
                            <Label Text="Valor do Pagamento:" FontSize="14" />
                            <Entry x:Name="ValorPagamentoEntry"
                                   Keyboard="Numeric"
                                   Placeholder="0,00"
                                   TextChanged="ValorPagamentoEntry_TextChanged" />
                            <Label x:Name="PagamentoParcialLabel"
                                   Text="Pagamento parcial - restará R$ 0,00"
                                   FontSize="12"
                                   TextColor="{StaticResource WarningColor}"
                                   IsVisible="False" />
                        </StackLayout>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- Observações -->
            <Frame Padding="15" CornerRadius="8" BorderColor="LightGray" HasShadow="True">
                <StackLayout Spacing="8">
                    <Label Text="Observações (opcional):" FontSize="14" />
                    <Editor x:Name="ObservacoesEditor"
                            HeightRequest="80"
                            Placeholder="Informações adicionais sobre o pagamento..." />
                </StackLayout>
            </Frame>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                <Button Grid.Column="0"
                        x:Name="SalvarButton"
                        Text="Registrar Pagamento"
                        Clicked="SalvarButton_Clicked"
                        Style="{StaticResource SuccessButton}" />

                <Button Grid.Column="1"
                        x:Name="CancelarButton"
                        Text="Cancelar"
                        Clicked="CancelarButton_Clicked"
                        Style="{StaticResource CancelButton}" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
