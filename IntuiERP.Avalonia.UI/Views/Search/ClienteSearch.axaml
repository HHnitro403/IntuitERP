<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:IntuiERP.Avalonia.UI.models"
             xmlns:helpers="clr-namespace:IntuiERP.Avalonia.UI.Helpers"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="IntuiERP.Avalonia.UI.Views.Search.ClienteSearch"
             Background="{DynamicResource SystemRegionBrush}">

    <UserControl.Resources>
        <helpers:BoolToStatusConverter x:Key="BoolToStatusConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.ActionBtn">
            <Setter Property="Height" Value="45" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Background="#1B4F83" Padding="20,15">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button x:Name="BtnBack" Content="Voltar" Background="Transparent" Foreground="White" BorderBrush="White" BorderThickness="1" />
                <TextBlock Grid.Column="1" Text="Clientes Cadastrados" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Search and Actions -->
        <StackPanel Grid.Row="1" Margin="15" Spacing="10">
            <TextBox x:Name="ClienteSearchBar" PlaceholderText="Buscar cliente por nome, email ou CPF..." />
            
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                <Button x:Name="NovoClienteButton" Content="Novo" Classes="ActionBtn" Background="#28A745" Foreground="White" />
                <Button x:Name="EditarClienteButton" Content="Editar" Classes="ActionBtn" Background="#FFC107" Foreground="#212529" IsEnabled="False" Grid.Column="1" />
                <Button x:Name="ExcluirClienteButton" Content="Excluir" Classes="ActionBtn" Background="#DC3545" Foreground="White" IsEnabled="False" Grid.Column="2" />
            </Grid>
        </StackPanel>

        <!-- List -->
        <Border Grid.Row="2" Margin="15,0,15,15" Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" BoxShadow="0 4 15 0 #1A000000" ClipToBounds="True">
            <ListBox x:Name="ClientesListBox" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:ClienteModel">
                        <StackPanel Margin="10" Spacing="2">
                            <TextBlock Text="{Binding Nome}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource FieldLabelColor}" />
                            <TextBlock Text="{Binding Email}" FontSize="14" Foreground="{DynamicResource FieldLabelColor}" Opacity="0.8" />
                            <TextBlock Text="{Binding CPF}" FontSize="14" Foreground="{DynamicResource FieldLabelColor}" Opacity="0.8" />
                            <TextBlock FontSize="12" Foreground="Gray">
                                <TextBlock.Text>
                                    <Binding Path="Ativo" Converter="{StaticResource BoolToStatusConverter}" StringFormat="Status: {0}" />
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>