<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:IntuiERP.Avalonia.UI.models"
             xmlns:helpers="clr-namespace:IntuiERP.Avalonia.UI.Helpers"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="IntuiERP.Avalonia.UI.Views.Search.FornecedorSearch"
             Background="{DynamicResource SystemRegionBrush}">

    <UserControl.Resources>
        <helpers:BoolToStatusConverter x:Key="BoolToStatusConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.ActionBtn">
            <Setter Property="Height" Value="45" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Background="#1B4F83" Padding="20,15">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button x:Name="BtnBack" Content="Voltar" Background="Transparent" Foreground="White" BorderBrush="White" BorderThickness="1" />
                <TextBlock Grid.Column="1" Text="Fornecedores Cadastrados" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Search and Actions -->
        <StackPanel Grid.Row="1" Margin="15" Spacing="10">
            <TextBox x:Name="FornecedorSearchBar" PlaceholderText="Buscar fornecedor por nome, CNPJ ou email..." />
            
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                <Button x:Name="NovoFornecedorButton" Content="Novo" Classes="ActionBtn" Background="#28A745" Foreground="White" />
                <Button x:Name="EditarFornecedorButton" Content="Editar" Classes="ActionBtn" Background="#FFC107" Foreground="#212529" IsEnabled="False" Grid.Column="1" />
                <Button x:Name="ExcluirFornecedorButton" Content="Excluir" Classes="ActionBtn" Background="#DC3545" Foreground="White" IsEnabled="False" Grid.Column="2" />
            </Grid>
        </StackPanel>

        <!-- List -->
        <Border Grid.Row="2" Margin="15,0,15,15" Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" BoxShadow="0 4 15 0 #1A000000" ClipToBounds="True">
            <ListBox x:Name="FornecedoresListBox" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:FornecedorModel">
                        <StackPanel Margin="10" Spacing="2">
                            <TextBlock FontWeight="Bold" FontSize="16" Foreground="{DynamicResource FieldLabelColor}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Cód: {0} - {1}">
                                        <Binding Path="CodFornecedor" />
                                        <Binding Path="NomeFantasia" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="{Binding RazaoSocial, StringFormat='Razão Social: {0}'}" FontSize="12" Foreground="{DynamicResource FieldLabelColor}" Opacity="0.7" />
                            <Grid ColumnDefinitions="*, *">
                                <TextBlock Grid.Column="0" Text="{Binding CNPJ, StringFormat='CNPJ: {0}'}" FontSize="12" Foreground="{DynamicResource FieldLabelColor}" Opacity="0.7" />
                                <TextBlock Grid.Column="1" HorizontalAlignment="Right" FontSize="12">
                                    <TextBlock.Text>
                                        <Binding Path="Ativo" Converter="{StaticResource BoolToStatusConverter}" StringFormat="Status: {0}" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>