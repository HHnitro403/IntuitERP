<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="IntuitERP.Desktop.Views.MainMenuView">

    <Grid RowDefinitions="Auto, *">
        <!-- Top Header -->
        <Border Grid.Row="0" Background="#1B4F83" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="ERP System" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        <TextBlock x:Name="WelcomeLabel" Text="Bem-vindo, Usuário" Foreground="White" FontSize="14" Opacity="0.9"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="DataLabel" Text="24/04/2025" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.9"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="280, *">
            <!-- Left Sidebar -->
            <ScrollViewer Grid.Column="0" Background="{DynamicResource CardBackgroundColor}">
                <Border Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Dashboard" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Cadastros" FontWeight="Bold"/>
                                <Button x:Name="ProdutosButton" Content="Produtos" HorizontalAlignment="Stretch" Classes="MenuButton"/>
                                <Button x:Name="ClientesButton" Content="Clientes" HorizontalAlignment="Stretch" Classes="MenuButton"/>
                                <Button x:Name="FornecedoresButton" Content="Fornecedores" HorizontalAlignment="Stretch" Classes="MenuButton"/>
                                <Button x:Name="UsuariosButton" Content="Usuários" HorizontalAlignment="Stretch" Classes="MenuButton"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Operações" FontWeight="Bold"/>
                                <Button x:Name="ComprasButton" Content="Compras" HorizontalAlignment="Stretch" Classes="MenuButton"/>
                                <Button x:Name="VendasButton" Content="Vendas" HorizontalAlignment="Stretch" Classes="MenuButton"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Financeiro" FontWeight="Bold"/>
                                <Button x:Name="ContasReceberButton" Content="Contas a Receber" HorizontalAlignment="Stretch" Classes="MenuButton"/>
                                <Button x:Name="ContasPagarButton" Content="Contas a Pagar" HorizontalAlignment="Stretch" Classes="MenuButton"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Right Dashboard Area -->
            <ScrollViewer Grid.Column="1">
                <Border Padding="25">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Resumo do Mês" FontSize="28" FontWeight="Bold"/>

                        <Grid ColumnDefinitions="*, *, *" ColumnSpacing="20">
                            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundColor}" Padding="15" CornerRadius="12">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Vendas" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource SecondaryTextColor}"/>
                                    <TextBlock x:Name="TotalVendasMes" Text="R$ 0,00" FontSize="24" FontWeight="Bold" Foreground="#55A2D3"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{DynamicResource CardBackgroundColor}" Padding="15" CornerRadius="12">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Despesas" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource SecondaryTextColor}"/>
                                    <TextBlock x:Name="TotalDespesasMes" Text="R$ 0,00" FontSize="24" FontWeight="Bold" Foreground="#55A2D3"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundColor}" Padding="15" CornerRadius="12">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Estoque" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource SecondaryTextColor}"/>
                                    <TextBlock x:Name="TotalProdutos" Text="0" FontSize="24" FontWeight="Bold" Foreground="#55A2D3"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <!-- Recent Orders Placeholder -->
                        <Border Background="{DynamicResource CardBackgroundColor}" Padding="15" CornerRadius="12">
                            <StackPanel Spacing="15">
                                <TextBlock Text="Pedidos Recentes" FontWeight="Bold" FontSize="18"/>
                                <ListBox x:Name="RecentOrdersList" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="10">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding NomeCliente}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding NomeVendedor}" FontSize="12" Opacity="0.7"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding ValorTotal, StringFormat='{}{0:C}'}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding DataVenda, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="12" Opacity="0.7" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.MenuButton">
            <Setter Property="Background" Value="#55A2D3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Styles>
</UserControl>
