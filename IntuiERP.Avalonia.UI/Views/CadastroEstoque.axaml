<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:IntuiERP.Avalonia.UI.models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="IntuiERP.Avalonia.UI.Views.CadastroEstoque"
             Background="{DynamicResource SystemRegionBrush}">

    <UserControl.Styles>
        <Style Selector="TextBlock.FormLabel">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource FieldLabelColor}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style Selector="Border.FormField">
            <Setter Property="Height" Value="45" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
        </Style>

        <Style Selector="TextBox.InputField">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="Button.PrimaryAction">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Height" Value="45" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.SecondaryAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource FieldLabelColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Height" Value="45" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#1B4F83" Padding="20,15">
            <TextBlock Text="Nova Movimentação de Estoque" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
        </Border>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="15" Margin="20">
                <Border Padding="20, 25" Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" BoxShadow="0 4 15 0 #1A000000">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Detalhes da Movimentação" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource FieldLabelColor}" />
                        <Separator Background="{DynamicResource BorderBrushColor}" />

                        <!-- Produto -->
                        <StackPanel>
                            <TextBlock Text="Produto:" Classes="FormLabel" />
                            <ComboBox x:Name="ProdutoComboBox" HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:ProdutoModel">
                                        <TextBlock Text="{Binding Descricao}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Tipo & Quantidade -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tipo de Movimentação:" Classes="FormLabel" />
                                <ComboBox x:Name="TipoMovimentacaoComboBox" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="E - Entrada" Tag="E" />
                                    <ComboBoxItem Content="S - Saída" Tag="S" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Quantidade:" Classes="FormLabel" />
                                <Border Classes="FormField">
                                    <TextBox x:Name="QuantidadeEntry" PlaceholderText="0.00" Classes="InputField" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Data -->
                        <StackPanel>
                            <TextBlock Text="Data da Movimentação:" Classes="FormLabel" />
                            <CalendarDatePicker x:Name="DataMovimentacaoPicker" HorizontalAlignment="Stretch" />
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="20" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Button x:Name="CancelarButton" Content="Cancelar" Classes="SecondaryAction" HorizontalAlignment="Stretch" />
                <Button x:Name="SalvarButton" Grid.Column="1" Content="Salvar" Classes="PrimaryAction" HorizontalAlignment="Stretch" />
            </Grid>
        </Border>
    </Grid>
</UserControl>