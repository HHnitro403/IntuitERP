<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="IntuitERP.Desktop.Views.LoginView">
    
    <Grid Background="{DynamicResource PageBackgroundColor}">
        <Border Width="400" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                Background="{DynamicResource CardBackgroundColor}"
                CornerRadius="20"
                Padding="30">
            <Border.BoxShadow>
                <BoxShadows>0 8 30 0 #1A000000</BoxShadows>
            </Border.BoxShadow>

            <StackPanel Spacing="25">
                <!-- Logo Placeholder -->
                <Image Source="avares://IntuitERP.Desktop/Assets/avalonia-logo.ico" 
                       Height="100" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

                <StackPanel Spacing="15">
                    <!-- Username -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Usuário" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextColor}"/>
                        <TextBox x:Name="UserEntry" 
                                 Watermark="Digite o seu Usuário" 
                                 Height="45"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock x:Name="UserErrorLabel" IsVisible="False" Foreground="Red" FontSize="12"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Senha" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextColor}"/>
                        <TextBox x:Name="PasswordEntry" 
                                 Watermark="Digite a sua Senha" 
                                 PasswordChar="*"
                                 Height="45"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock x:Name="PasswordErrorLabel" IsVisible="False" Foreground="Red" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="LoginButton" 
                        Content="LOGIN" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center"
                        Height="50"
                        Background="#55A2D3"
                        Foreground="White"
                        FontWeight="Bold"
                        CornerRadius="5"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
