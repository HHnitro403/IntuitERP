<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DBConfigurator.Avalonia.UI.Models"
        xmlns:local="clr-namespace:DBConfigurator.Avalonia.UI"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
        x:Class="DBConfigurator.Avalonia.UI.MainWindow"
        x:CompileBindings="True"
        x:DataType="local:MainWindow"
        Title="IntuitERP - Database User Configurator"
        Width="700" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SystemRegionBrush}">

    <Grid RowDefinitions="Auto, *">
        <!-- TOP BAR / THEME TOGGLE -->
        <Border Grid.Row="0" Padding="10" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Toggle Theme" Command="{Binding ToggleThemeCommand}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <!-- LOGIN VIEW -->
            <Grid x:Name="LoginGrid" IsVisible="True" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" CornerRadius="10" Padding="40" BoxShadow="0 10 30 0 #20000000">
                    <StackPanel Spacing="15" Width="300">
                        <TextBlock Text="Admin Login" Classes="header" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBox x:Name="AdminUserEntry" PlaceholderText="Username" Text="BbAdmin" Height="40" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="AdminPassEntry" PlaceholderText="Password" PasswordChar="●" Height="40" VerticalContentAlignment="Center"/>
                        <Button Content="Login" Command="{Binding LoginCommand}" Classes="primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="40" Margin="0,10,0,0"/>
                        <TextBlock x:Name="LoginErrorLabel" Foreground="#F44336" FontSize="14" IsVisible="False" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- MAIN TABBED VIEW -->
            <TabControl x:Name="MainTabControl" IsVisible="False" Margin="10">
                <!-- TAB 1: DATABASE CONFIG -->
                <TabItem Header="Database Configuration">
                    <Grid RowDefinitions="Auto, *">
                        <StackPanel Grid.Row="0" Margin="20" Spacing="15">
                            <TextBlock Text="PostgreSQL Configuration" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColor}"/>
                            
                            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto, *">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Server:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="ServerEntry" Margin="0,8" PlaceholderText="e.g., localhost or supabase.co"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="PortEntry" Text="5432" Margin="0,8"/>
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Database:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="DatabaseEntry" Margin="0,8" PlaceholderText="e.g., intuiterp_db"/>
                                    
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="UserEntry" Margin="0,8" PlaceholderText="e.g., postgres"/>
                                    
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="PasswordEntry" PasswordChar="●" Margin="0,8"/>
                                </Grid>
                            </Border>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                                <Button Content="Test Connection" Command="{Binding TestConnectionCommand}" Padding="20,10"/>
                                <Button Content="Save Configuration" Command="{Binding SaveConfigCommand}" Classes="primary" Padding="20,10"/>
                                <Button Content="Clear Form" Command="{Binding ClearFormCommand}" Padding="20,10"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="ConnectionTestResultLabel" IsVisible="False" HorizontalAlignment="Center" FontWeight="Bold" TextWrapping="Wrap" FontSize="14" Margin="0,10"/>
                            <Separator Margin="0,5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="20,0,20,20" Spacing="10">
                            <TextBlock Text="Saved Configurations" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <ListBox x:Name="ConfigsListBox" SelectionChanged="OnSelectionChanged" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="8" MinHeight="150">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:Configuration">
                                        <Grid ColumnDefinitions="*, Auto" Margin="5">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Server, StringFormat='Server: {0}'}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                                <TextBlock Text="{Binding DataBase, StringFormat='Database: {0}'}" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Delete" Foreground="White" Background="#F44336" 
                                                    Command="{Binding $parent[Window].((local:MainWindow)DataContext).DeleteConfigCommand}" 
                                                    CommandParameter="{Binding}"
                                                    Padding="15,5" CornerRadius="5"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- TAB 2: USER MANAGEMENT -->
                <TabItem Header="User Management">
                    <Grid RowDefinitions="Auto, *">
                        <StackPanel Grid.Row="0" Margin="20" Spacing="15">
                            <TextBlock Text="ERP User Management" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColor}"/>
                            
                            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto, *">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBox x:Name="ERPUserEntry" Grid.Row="0" Grid.Column="1" Margin="0,8" PlaceholderText="New username"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBox x:Name="ERPPassEntry" Grid.Row="1" Grid.Column="1" PasswordChar="●" Margin="0,8" PlaceholderText="New password"/>
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Profile:" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <ComboBox x:Name="ProfileComboBox" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,8">
                                        <ComboBoxItem Content="User (Read-Only)"/>
                                        <ComboBoxItem Content="Administrator (Full)"/>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                                <Button Content="Create User" Command="{Binding CreateUserCommand}" Classes="primary" Padding="20,10"/>
                                <Button Content="Refresh List" Command="{Binding RefreshUsersCommand}" Padding="20,10"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="UserActionStatusLabel" IsVisible="False" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,10"/>
                            <Separator Margin="0,5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="20,0,20,20" Spacing="10">
                            <TextBlock Text="Existing ERP Users" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <ListBox x:Name="UsersListBox" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="8" MinHeight="150">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="local:UserViewModel">
                                        <Grid ColumnDefinitions="*, Auto" Margin="5">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding usuario}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                                <TextBlock Text="Permissions: Active" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Delete" Foreground="White" Background="#F44336" 
                                                    Command="{Binding $parent[Window].((local:MainWindow)DataContext).DeleteUserCommand}" 
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding IsNotSysAdmin}"
                                                    Padding="15,5" CornerRadius="5"/>
                                        </Grid>                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>