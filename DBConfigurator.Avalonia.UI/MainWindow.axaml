<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DBConfigurator.Avalonia.UI.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="DBConfigurator.Avalonia.UI.MainWindow"
        Title="IntuitERP - Database Configurator"
        Width="600" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- LOGIN VIEW -->
        <Grid x:Name="LoginGrid" IsVisible="True" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Background="White" CornerRadius="10" Padding="30" BoxShadow="0 4 20 0 #40000000">
                <StackPanel Spacing="15" Width="300">
                    <TextBlock Text="Admin Login" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="AdminUserEntry" PlaceholderText="Username" Text="BbAdmin"/>
                    <TextBox x:Name="AdminPassEntry" PlaceholderText="Password" PasswordChar="●"/>
                    <Button Content="Login" Click="OnLoginClicked" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <TextBlock x:Name="LoginErrorLabel" Foreground="Red" FontSize="12" IsVisible="False" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CONFIGURATION VIEW -->
        <Grid x:Name="MainGrid" IsVisible="False" RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" Margin="20" Spacing="15">
                <TextBlock Text="PostgreSQL Configuration" FontSize="20" FontWeight="Bold"/>
                
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="15">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Server:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="ServerEntry" Margin="0,5"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Database:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="DatabaseEntry" Margin="0,5"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="UserEntry" Margin="0,5"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="PasswordEntry" PasswordChar="●" Margin="0,5"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                    <Button Content="Save Configuration" Click="OnSaveClicked" Classes="primary"/>
                    <Button Content="Clear Form" Click="OnClearClicked"/>
                </StackPanel>
                
                <Separator Margin="0,10"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="20,0,20,20" Spacing="10">
                <TextBlock Text="Saved Configurations" FontSize="18" FontWeight="Bold"/>
                <ListBox x:Name="ConfigsListBox" SelectionChanged="OnSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Configuration">
                            <Grid ColumnDefinitions="*, Auto" Margin="5">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Server, StringFormat='Server: {0}'}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding DataBase, StringFormat='Database: {0}'}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Delete" Foreground="White" Background="Red" 
                                        Click="OnDeleteClicked" Tag="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
